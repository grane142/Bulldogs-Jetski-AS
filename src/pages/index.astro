---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Bulldogg Jetski - Premium Vannscooter Utleie" description="Opplev spenningen med vannscooter. Bulldogg Jetski tilbyr premium vannscooter utleie med førsteklasses service.">

    <!-- ========== NAVIGATION ========== -->
    <nav class="nav" id="nav">
        <div class="nav__inner">
            <a href="#" class="nav__logo">Bulldogg Jetski</a>
            <ul class="nav__links">
                <li><a href="#about">Om Oss</a></li>
                <li><a href="#overview">Vannscootere</a></li>
                <li><a href="#discover">Priser</a></li>
                <li><a href="#testimonials">Anmeldelser</a></li>
                <li><a href="#contact">Kontakt</a></li>
            </ul>
            <div class="nav__cta">
                <a href="#contact" class="btn-primary">
                    Book Nå
                    <span class="arrow-icon">
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                </a>
            </div>
            <div class="nav__mobile-toggle" id="mobileToggle" aria-label="Open menu">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </nav>

    <!-- Mobile Menu -->
    <div class="nav__mobile-menu" id="mobileMenu">
        <div class="nav__mobile-close" id="mobileClose" aria-label="Close menu"></div>
        <a href="#about" class="mobile-link">Om Oss</a>
        <a href="#overview" class="mobile-link">Vannscootere</a>
        <a href="#discover" class="mobile-link">Priser</a>
        <a href="#testimonials" class="mobile-link">Anmeldelser</a>
        <a href="#contact" class="mobile-link">Kontakt</a>
        <a href="#contact" class="btn-primary" style="margin-top: 20px;">
            Book Nå
            <span class="arrow-icon">
                <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </span>
        </a>
    </div>

    <!-- ========== HERO ========== -->
    <section class="hero" id="hero">
        <div class="hero__video-bg">
            <video autoplay muted loop playsinline>
                <source src="https://assets.cdn.filesafe.space/qVvcmGRblTyzZyqPlbTr/media/69d212e684c045c2745a4dc5.mp4" type="video/mp4">
            </video>
        </div>
        <div class="hero__content">
            <p class="hero__label">Premium Vannscooter Utleie</p>
            <h1 class="hero__title">Opplev spenningen på vannet.</h1>
            <p class="hero__subtitle">Lei en vannscooter og opplev friheten og adrenalinet på sjøen med Bulldogg Jetski.</p>
            <div class="hero__cta">
                <a href="#overview" class="btn-outline">
                    Utforsk Vannscootere
                    <span class="arrow-icon">
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                </a>
            </div>
        </div>
    </section>

    <!-- ========== ABOUT ========== -->
    <section class="about" id="about">
        <div class="container">
            <div class="about__top">
                <div class="about__left animate-on-scroll">
                    <p class="about__label-text">Uanstrengt &bull; Eventyrlig &bull; Premium</p>
                    <p class="about__text">Vi tilbyr en sømløs vannscooteropplevelse designet for frihet, komfort og oppdagelse.</p>
                    <a href="#overview" class="about__btn">Om Oss</a>
                </div>
                <div class="about__right animate-on-scroll animate-delay-1">
                    <div class="about__right-image">
                        <img src="https://assets.cdn.filesafe.space/qVvcmGRblTyzZyqPlbTr/media/69d216d54cde4bbc2aca05e5.jpg" alt="Vannscooter på sjøen">
                        <div class="about__right-overlay">
                            <p>Vårt lidenskapelige team er dedikert til sikkerhet, komfort og service. Uansett hvor vannet kaller, er Bulldogg Jetski her for å hjelpe.</p>
                        </div>
                    </div>
                </div>
            </div>

            <p class="about__bottom-desc animate-on-scroll animate-delay-2">Bulldogg Jetski er mer enn bare en utleietjeneste — det er din inngangsport til uforglemmelige opplevelser på vannet. Vi startet med en enkel visjon: å gjøre vannscooterkjøring tilgjengelig, stilfullt og stressfritt. I dag hjelper vi eventyrere, familier og utforskere med å skape minner som varer livet ut.</p>

            <div class="about__stats animate-on-scroll animate-delay-3">
                <div class="about__stat">
                    <div class="about__stat-number">15+</div>
                    <div class="about__stat-label">Vannscootere i Flåten</div>
                </div>
                <div class="about__stat">
                    <div class="about__stat-number">2K+</div>
                    <div class="about__stat-label">Fornøyde Kunder</div>
                </div>
                <div class="about__stat">
                    <div class="about__stat-number">8+</div>
                    <div class="about__stat-label">Års Erfaring</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ========== OVERVIEW ========== -->
    <section class="overview" id="overview">
        <div class="container">
            <div class="overview__header animate-on-scroll">
                <p class="overview__label">Vannscooter Oversikt</p>
                <h2 class="overview__boat-name" id="overviewName">Yamaha WaveRunner</h2>
                <p class="overview__boat-desc" id="overviewDesc">Perfekt for familier og nybegynnere. Stabil, komfortabel vannscooter med plass til 3 passasjerer og enkel håndtering på åpent vann.</p>
                <a href="#contact" class="overview__boat-btn">
                    Se Mer
                    <svg viewBox="0 0 16 16" fill="none" width="16" height="16"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
            </div>

            <div class="overview__image-wrapper animate-on-scroll animate-delay-1">
                <div class="overview__nav">
                    <button class="overview__nav-btn" id="overviewPrev" aria-label="Forrige">
                        <svg viewBox="0 0 16 16" fill="none"><path d="M10 4l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                    <button class="overview__nav-btn" id="overviewNext" aria-label="Neste">
                        <svg viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                </div>
                <img id="overviewImage" src="https://assets.cdn.filesafe.space/qVvcmGRblTyzZyqPlbTr/media/69c538594880be32be7897a3.webp" alt="Yamaha WaveRunner">
            </div>

            <div class="overview__stats animate-on-scroll animate-delay-2">
                <div class="overview__stat">
                    <div class="overview__stat-label">Motor</div>
                    <div class="overview__stat-value" id="overviewStat1">180 HK</div>
                </div>
                <div class="overview__stat">
                    <div class="overview__stat-label">Topphastighet</div>
                    <div class="overview__stat-value" id="overviewStat2">105 km/t</div>
                </div>
                <div class="overview__stat">
                    <div class="overview__stat-label">Passasjerer</div>
                    <div class="overview__stat-value" id="overviewStat3">Opptil 3</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ========== PRISPAKKER ========== -->
    <section class="discover" id="discover">
        <div class="container">
            <div class="discover__header animate-on-scroll" style="display:flex;align-items:flex-end;justify-content:space-between;text-align:left;">
                <div>
                    <span class="section-label section-label--dark">Priser &bull; Pakker</span>
                    <h2 class="discover__title" style="margin-top:24px;margin-left:0;">Velg pakken som passer deg</h2>
                </div>
                <a href="#contact" class="discover__card-link" style="flex-shrink:0;">
                    Book Nå
                    <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
            </div>

            <div class="discover__grid" style="grid-template-columns: repeat(2, 1fr);">
                <!-- Halvdag -->
                <div class="discover__card animate-on-scroll animate-delay-1">
                    <div class="discover__card-body">
                        <h3 class="discover__card-name">Halvdag</h3>
                        <div class="discover__card-price">1 750,-</div>
                        <p class="discover__card-price-sub">eks. mva / per vannscooter</p>
                        <div class="discover__card-features">
                            <div class="discover__card-feature">
                                <svg viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Opptil 4 timer på vannet
                            </div>
                            <div class="discover__card-feature">
                                <svg viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Sikkerhetsutstyr inkludert
                            </div>
                            <div class="discover__card-feature">
                                <svg viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Opplæring og instruksjon
                            </div>
                            <div class="discover__card-feature">
                                <svg viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Levering innenfor Oslo, Asker og Drøbak
                            </div>
                        </div>
                        <a href="#contact" class="discover__card-link">
                            Book Halvdag
                            <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </a>
                    </div>
                </div>
                <!-- Heldag -->
                <div class="discover__card animate-on-scroll animate-delay-2">
                    <div class="discover__card-body">
                        <h3 class="discover__card-name">Heldag</h3>
                        <div class="discover__card-price">3 500,-</div>
                        <p class="discover__card-price-sub">eks. mva / per vannscooter</p>
                        <div class="discover__card-features">
                            <div class="discover__card-feature">
                                <svg viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Full dag på vannet
                            </div>
                            <div class="discover__card-feature">
                                <svg viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Sikkerhetsutstyr inkludert
                            </div>
                            <div class="discover__card-feature">
                                <svg viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Opplæring og instruksjon
                            </div>
                            <div class="discover__card-feature">
                                <svg viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Levering innenfor Oslo, Asker og Drøbak
                            </div>
                            <div class="discover__card-feature">
                                <svg viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Beste verdi for pengene
                            </div>
                        </div>
                        <a href="#contact" class="discover__card-link">
                            Book Heldag
                            <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Områder -->
            <div class="discover__areas animate-on-scroll animate-delay-3">
                <div class="discover__areas-title">Vi dekker Oslofjorden</div>
                <p class="discover__areas-text">Leveres til der du vil innenfor våre områder</p>
                <div class="discover__areas-locations">
                    <div class="discover__areas-location">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Oslo
                    </div>
                    <div class="discover__areas-location">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Asker
                    </div>
                    <div class="discover__areas-location">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Drøbak
                    </div>
                </div>
                <p class="discover__areas-text" style="margin-top:12px;font-size:13px;">Alle priser eks. mva</p>
            </div>
        </div>
    </section>

    <!-- ========== FEATURE/INTERIOR ========== -->
    <section class="feature">
        <div class="feature__bg">
            <img src="https://assets.cdn.filesafe.space/qVvcmGRblTyzZyqPlbTr/media/69d216d54cde4bbc2aca05e3.jpg" alt="Vannscooter på sjøen">
        </div>
        <div class="container">
            <div class="feature__content animate-on-scroll">
                <span class="section-label">Utstyrt For Eventyr</span>
                <h2 class="feature__title" style="margin-top:24px;">Førsteklasses utstyr og sikkerhet</h2>
                <p class="feature__desc">Alle våre vannscootere er utstyrt med det nyeste innen sikkerhetsutstyr, GPS-navigasjon og komfortfunksjoner for en trygg og spennende opplevelse.</p>
                <a href="#contact" class="btn-primary">
                    Book Din Tur
                    <span class="arrow-icon">
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                </a>
            </div>
        </div>
    </section>

    <!-- ========== FOUNDER ========== -->
    <section class="founder" id="founder">
        <div class="container">
            <div class="founder__inner">
                <div class="founder__left animate-on-scroll">
                    <span class="section-label section-label--dark">Vår Grunnlegger</span>
                    <h2 class="founder__title" style="margin-top:24px;">Lidenskap for vannsport og eventyr</h2>
                    <p class="founder__desc">Med over 8 års erfaring innen vannsport og utleie har vi bygget Bulldogg Jetski med fokus på sikkerhet, kvalitet og uforglemmelige opplevelser for alle våre kunder.</p>

                    <div class="founder__benefits">
                        <div class="founder__benefit">
                            <div class="founder__benefit-icon">
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                            <div class="founder__benefit-text">
                                <h4>Sikkerhet Først</h4>
                                <p>Fullt forsikret flåte med profesjonell sikkerhetsopplæring før hver tur.</p>
                            </div>
                        </div>
                        <div class="founder__benefit">
                            <div class="founder__benefit-icon">
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                            <div class="founder__benefit-text">
                                <h4>Premium Utstyr</h4>
                                <p>Kun toppmodeller fra ledende produsenter, vedlikeholdt til perfeksjon.</p>
                            </div>
                        </div>
                        <div class="founder__benefit">
                            <div class="founder__benefit-icon">
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                            <div class="founder__benefit-text">
                                <h4>Personlig Service</h4>
                                <p>Dedikert team som sørger for at hver kunde får en skreddersydd opplevelse.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="founder__right animate-on-scroll animate-delay-2">
                    <div class="founder__image">
                        <img src="https://images.pexels.com/photos/1576610/pexels-photo-1576610.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Grunnlegger">
                    </div>
                    <div class="founder__quote">
                        <p class="founder__quote-text">"Vår visjon er å gi alle muligheten til å oppleve friheten og spenningen på vannet, uansett erfaring."</p>
                        <div class="founder__quote-author">
                            <div class="founder__quote-avatar">
                                <img src="https://images.pexels.com/photos/1576610/pexels-photo-1576610.jpeg?auto=compress&cs=tinysrgb&w=100" alt="Avatar">
                            </div>
                            <div>
                                <div class="founder__quote-name">Bulldogg Jetski</div>
                                <div class="founder__quote-role">Grunnlegger & Daglig Leder</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ========== TESTIMONIALS ========== -->
    <section class="testimonials" id="testimonials">
        <div class="container">
            <div class="testimonials__header">
                <div class="testimonials__header-left animate-on-scroll">
                    <span class="section-label section-label--dark">Kundeomtaler</span>
                    <h2 class="testimonials__title" style="margin-top:24px;">Hva våre kunder sier</h2>
                </div>
                <div class="testimonials__nav">
                    <button class="testimonials__nav-btn" id="testimonialsPrev" aria-label="Forrige">
                        <svg viewBox="0 0 16 16" fill="none"><path d="M10 4l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                    <button class="testimonials__nav-btn" id="testimonialsNext" aria-label="Neste">
                        <svg viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                </div>
            </div>

            <div class="testimonials__carousel">
                <div class="testimonials__track" id="testimonialsTrack">
                    <!-- Slide 1 -->
                    <div class="testimonials__slide">
                        <div class="testimonial-card">
                            <div class="testimonial-card__stars">
                                <svg viewBox="0 0 16 16"><path d="M8 1l2.24 4.54 5.01.73-3.63 3.53.86 4.99L8 12.27l-4.48 2.52.86-4.99L.75 6.27l5.01-.73L8 1z"/></svg>
                                <svg viewBox="0 0 16 16"><path d="M8 1l2.24 4.54 5.01.73-3.63 3.53.86 4.99L8 12.27l-4.48 2.52.86-4.99L.75 6.27l5.01-.73L8 1z"/></svg>
                                <svg viewBox="0 0 16 16"><path d="M8 1l2.24 4.54 5.01.73-3.63 3.53.86 4.99L8 12.27l-4.48 2.52.86-4.99L.75 6.27l5.01-.73L8 1z"/></svg>
                                <svg viewBox="0 0 16 16"><path d="M8 1l2.24 4.54 5.01.73-3.63 3.53.86 4.99L8 12.27l-4.48 2.52.86-4.99L.75 6.27l5.01-.73L8 1z"/></svg>
                                <svg viewBox="0 0 16 16"><path d="M8 1l2.24 4.54 5.01.73-3.63 3.53.86 4.99L8 12.27l-4.48 2.52.86-4.99L.75 6.27l5.01-.73L8 1z"/></svg>
                            </div>
                            <p class="testimonial-card__text">Fantastisk opplevelse! Vannscooterne var i toppstand og personalet var utrolig hjelpsomme. Vi kommer definitivt tilbake neste sommer.</p>
                            <div class="testimonial-card__author">
                                <div class="testimonial-card__avatar">
                                    <img src="https://images.pexels.com/photos/1222271/pexels-photo-1222271.jpeg?auto=compress&cs=tinysrgb&w=100" alt="Erik Hansen">
                                </div>
                                <div>
                                    <div class="testimonial-card__name">Erik Hansen</div>
                                    <div class="testimonial-card__role">Stamkunde</div>
                                </div>
                            </div>
                        </div>
                        <div class="testimonial-card">
                            <div class="testimonial-card__stars">
                                <svg viewBox="0 0 16 16"><path d="M8 1l2.24 4.54 5.01.73-3.63 3.53.86 4.99L8 12.27l-4.48 2.52.86-4.99L.75 6.27l5.01-.73L8 1z"/></svg>
                                <svg viewBox="0 0 16 16"><path d="M8 1l2.24 4.54 5.01.73-3.63 3.53.86 4.99L8 12.27l-4.48 2.52.86-4.99L.75 6.27l5.01-.73L8 1z"/></svg>
                                <svg viewBox="0 0 16 16"><path d="M8 1l2.24 4.54 5.01.73-3.63 3.53.86 4.99L8 12.27l-4.48 2.52.86-4.99L.75 6.27l5.01-.73L8 1z"/></svg>
