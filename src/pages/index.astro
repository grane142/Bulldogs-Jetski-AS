    <!-- ========== BOOKING MODAL ========== -->
    <div class="booking-overlay" id="bookingOverlay"></div>
    <div class="booking-modal" id="bookingModal">
        <button class="booking-modal__close" id="bookingClose" aria-label="Lukk">
            <svg viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="booking-modal__header">
            <span class="section-label section-label--dark">Forespørsel</span>
            <h2 class="booking-modal__title">Send en forespørsel</h2>
            <p class="booking-modal__subtitle">Fyll ut skjemaet, så tar vi kontakt med deg innen kort tid for å bekrefte.</p>
        </div>
        <form class="booking-form" id="bookingForm">
            <!-- Honeypot (hidden from users, catches bots) -->
            <input type="text" name="honeypot" style="position:absolute;left:-9999px;opacity:0;height:0;" tabindex="-1" autocomplete="off">
            <div class="booking-form__row">
                <div class="booking-form__field">
                    <label for="bookingName">Navn</label>
                    <input type="text" id="bookingName" name="name" placeholder="Ditt fulle navn" required>
                </div>
                <div class="booking-form__field">
                    <label for="bookingPhone">Telefon</label>
                    <input type="tel" id="bookingPhone" name="phone" placeholder="Ditt telefonnummer" required>
                </div>
            </div>
            <div class="booking-form__row">
                <div class="booking-form__field">
                    <label for="bookingEmail">E-post</label>
                    <input type="email" id="bookingEmail" name="email" placeholder="Din e-postadresse" required>
                </div>
                <div class="booking-form__field">
                    <label for="bookingDate">Ønsket dato</label>
                    <input type="date" id="bookingDate" name="date" required>
                </div>
            </div>
            <div class="booking-form__row">
                <div class="booking-form__field">
                    <label for="bookingPackage">Pakke</label>
                    <select id="bookingPackage" name="package" required>
                        <option value="" disabled selected>Velg pakke</option>
                        <option value="timepris">Timepris — 1 300,-</option>
                        <option value="halvdag">Halvdag — 1 750,-</option>
                        <option value="heldag">Heldag — 3 500,-</option>
                        <option value="helgutleie">Helgutleie — Ved forespørsel</option>
                    </select>
                </div>
                <div class="booking-form__field">
                    <label for="bookingQty">Antall vannscootere</label>
                    <select id="bookingQty" name="quantity" required>
                        <option value="" disabled selected>Velg antall</option>
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                        <option value="5+">5+</option>
                    </select>
                </div>
            </div>
            <div class="booking-form__field">
                <label for="bookingMessage">Melding (valgfritt)</label>
                <textarea id="bookingMessage" name="message" rows="3" placeholder="Spesielle ønsker, spørsmål eller annet..."></textarea>
            </div>
            <button type="submit" class="btn-primary booking-form__submit">
                Send Forespørsel
                <span class="arrow-icon">
                    <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
            </button>
        </form>
        <div class="booking-modal__success" id="bookingSuccess" style="display:none;">
            <div class="booking-modal__success-icon">
                <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#16a34a" stroke-width="3"/><path d="M14 24l7 7 13-13" stroke="#16a34a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>Takk for din bestilling!</h3>
            <p>Vi har mottatt forespørselen din og tar kontakt innen kort tid. Sjekk gjerne e-posten din for bekreftelse.</p>
        </div>
    </div>

