    <!-- ========== JAVASCRIPT ========== -->
    <script>
        // ===== Force video autoplay on mobile =====
        const heroVideo = document.getElementById('heroVideo');
        if (heroVideo) {
            const tryPlay = () => {
                heroVideo.muted = true;
                const p = heroVideo.play();
                if (p) p.catch(() => {});
            };
            tryPlay();
            document.addEventListener('touchstart', tryPlay, { once: true });
            document.addEventListener('click', tryPlay, { once: true });
            heroVideo.addEventListener('loadeddata', tryPlay);
        }

        // ===== Nav scroll effect =====
        const nav = document.getElementById('nav');
        window.addEventListener('scroll', () => {
            nav.classList.toggle('scrolled', window.scrollY > 50);
        });

        // ===== Mobile menu =====
        const mobileToggle = document.getElementById('mobileToggle');
        const mobileMenu = document.getElementById('mobileMenu');
        const mobileClose = document.getElementById('mobileClose');

        mobileToggle.addEventListener('click', () => {
            mobileMenu.classList.add('active');
            document.body.style.overflow = 'hidden';
        });

        mobileClose.addEventListener('click', () => {
            mobileMenu.classList.remove('active');
            document.body.style.overflow = '';
        });

        document.querySelectorAll('.mobile-link').forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.remove('active');
                document.body.style.overflow = '';
            });
        });

        // ===== Smooth scroll =====
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                const href = this.getAttribute('href');
                if (href === '#contact') return; // handled by booking modal
                e.preventDefault();
                const target = document.querySelector(href);
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });

        // ===== Scroll animations =====
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, observerOptions);

        document.querySelectorAll('.animate-on-scroll').forEach(el => {
            observer.observe(el);
        });

        // ===== Overview Single-Boat Carousel =====
        const boatData = [
            {
                name: 'Yamaha WaveRunner',
                desc: 'Perfekt for familier og nybegynnere. Stabil, komfortabel vannscooter med plass til 3 passasjerer og enkel håndtering på åpent vann.',
                image: 'https://assets.cdn.filesafe.space/qVvcmGRblTyzZyqPlbTr/media/69c538594880be32be7897a3.webp',
                stat1: '180 HK', stat2: '105 km/t', stat3: 'Opptil 3'
            },
            {
                name: 'Sea-Doo GTX',
                desc: 'Kraftig og stilfull vannscooter med avansert teknologi for en komfortabel og spennende kjøreopplevelse på sjøen.',
                image: 'https://assets.cdn.filesafe.space/qVvcmGRblTyzZyqPlbTr/media/69d216d53d829c73b2383add.jpg',
                stat1: '230 HK', stat2: '110 km/t', stat3: 'Opptil 3'
            },
            {
                name: 'Kawasaki Ultra 310',
                desc: 'Den ultimate kraftpakken. Uovertruffen ytelse og presisjon for erfarne kjørere som søker ren adrenalin.',
                image: 'https://assets.cdn.filesafe.space/qVvcmGRblTyzZyqPlbTr/media/69d216d53d829c73b2383adc.jpg',
                stat1: '310 HK', stat2: '120 km/t', stat3: 'Opptil 3'
            },
            {
                name: 'Yamaha FX Cruiser',
                desc: 'Luksus på vannet. Premium komfort, stabil kjøring og kraftig motor gjør dette til den perfekte cruiser-opplevelsen.',
                image: 'https://assets.cdn.filesafe.space/qVvcmGRblTyzZyqPlbTr/media/69d216d54cde4bbc2aca05e3.jpg',
                stat1: '250 HK', stat2: '112 km/t', stat3: 'Opptil 3'
            },
            {
                name: 'Sea-Doo RXP-X',
                desc: 'Bygget for fart og konkurranser. Rå kraft og responsiv styring gir den mest intense vannscooteropplevelsen.',
                image: 'https://assets.cdn.filesafe.space/qVvcmGRblTyzZyqPlbTr/media/69d217154cde4bbc2aca0d6c.jpg',
                stat1: '300 HK', stat2: '118 km/t', stat3: 'Opptil 2'
            }
        ];

        const overviewPrev = document.getElementById('overviewPrev');
        const overviewNext = document.getElementById('overviewNext');
        const overviewName = document.getElementById('overviewName');
        const overviewDesc = document.getElementById('overviewDesc');
        const overviewImage = document.getElementById('overviewImage');
        const overviewStat1 = document.getElementById('overviewStat1');
        const overviewStat2 = document.getElementById('overviewStat2');
        const overviewStat3 = document.getElementById('overviewStat3');
        let overviewIndex = 0;
        const overviewTotal = boatData.length;

        function updateOverview() {
            const boat = boatData[overviewIndex];
            overviewName.style.opacity = '0';
            overviewDesc.style.opacity = '0';
            overviewImage.style.opacity = '0';

            setTimeout(() => {
                overviewName.textContent = boat.name;
                overviewDesc.textContent = boat.desc;
                overviewImage.src = boat.image;
                overviewImage.alt = boat.name;
                overviewStat1.textContent = boat.stat1;
                overviewStat2.textContent = boat.stat2;
                overviewStat3.textContent = boat.stat3;

                overviewName.style.opacity = '1';
                overviewDesc.style.opacity = '1';
                overviewImage.style.opacity = '1';
            }, 300);
        }

        overviewNext.addEventListener('click', () => {
            overviewIndex = (overviewIndex + 1) % overviewTotal;
            updateOverview();
        });

        overviewPrev.addEventListener('click', () => {
            overviewIndex = (overviewIndex - 1 + overviewTotal) % overviewTotal;
            updateOverview();
        });

        // ===== Testimonials Carousel =====
        const testimonialsTrack = document.getElementById('testimonialsTrack');
        const testimonialsPrev = document.getElementById('testimonialsPrev');
        const testimonialsNext = document.getElementById('testimonialsNext');
        let testimonialsIndex = 0;
        const testimonialsSlides = testimonialsTrack.querySelectorAll('.testimonials__slide');
        const testimonialsTotal = testimonialsSlides.length;

        function updateTestimonials() {
            testimonialsTrack.style.transform = `translateX(-${testimonialsIndex * 100}%)`;
        }

        testimonialsNext.addEventListener('click', () => {
            testimonialsIndex = (testimonialsIndex + 1) % testimonialsTotal;
            updateTestimonials();
        });

        testimonialsPrev.addEventListener('click', () => {
            testimonialsIndex = (testimonialsIndex - 1 + testimonialsTotal) % testimonialsTotal;
            updateTestimonials();
        });

        // ===== Swipe support for carousels =====
        function addSwipe(element, onLeft, onRight) {
            let startX = 0;
            let startY = 0;
            element.addEventListener('touchstart', (e) => {
                startX = e.touches[0].clientX;
                startY = e.touches[0].clientY;
            }, { passive: true });
            element.addEventListener('touchend', (e) => {
                const dx = e.changedTouches[0].clientX - startX;
                const dy = e.changedTouches[0].clientY - startY;
                if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
                    if (dx < 0) onLeft();
                    else onRight();
                }
            }, { passive: true });
        }

        // Overview carousel swipe
        const overviewWrapper = document.querySelector('.overview__image-wrapper');
        if (overviewWrapper) {
            addSwipe(overviewWrapper,
                () => { overviewIndex = (overviewIndex + 1) % overviewTotal; updateOverview(); },
                () => { overviewIndex = (overviewIndex - 1 + overviewTotal) % overviewTotal; updateOverview(); }
            );
        }

        // Testimonials carousel swipe
        addSwipe(testimonialsTrack,
            () => { testimonialsIndex = (testimonialsIndex + 1) % testimonialsTotal; updateTestimonials(); },
            () => { testimonialsIndex = (testimonialsIndex - 1 + testimonialsTotal) % testimonialsTotal; updateTestimonials(); }
        );

        // ===== Booking Modal =====
        const bookingModal = document.getElementById('bookingModal');
        const bookingOverlay = document.getElementById('bookingOverlay');
        const bookingClose = document.getElementById('bookingClose');
        const bookingForm = document.getElementById('bookingForm');
        const bookingSuccess = document.getElementById('bookingSuccess');
        const bookingPackage = document.getElementById('bookingPackage');

        function openBooking(packageValue) {
            bookingModal.classList.add('active');
            bookingOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
            if (packageValue) {
                bookingPackage.value = packageValue;
            }
        }

        function closeBooking() {
            bookingModal.classList.remove('active');
            bookingOverlay.classList.remove('active');
            document.body.style.overflow = '';
        }

        bookingClose.addEventListener('click', closeBooking);
        bookingOverlay.addEventListener('click', closeBooking);

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeBooking();
        });

        // Connect all booking buttons
        document.querySelectorAll('a[href="#contact"]').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                const text = btn.textContent.trim().toLowerCase();
                let pkg = '';
                if (text.includes('timepris') || text.includes('book nå')) pkg = '';
                if (text.includes('halvdag')) pkg = 'halvdag';
                if (text.includes('heldag')) pkg = 'heldag';
                if (text.includes('helgutleie') || text.includes('kontakt oss')) pkg = 'helgutleie';
                openBooking(pkg);
            });
        });

        // Form submission
        const submitBtn = bookingForm.querySelector('.booking-form__submit');

        bookingForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            // Disable button and show loading
            submitBtn.disabled = true;
            submitBtn.innerHTML = 'Sender...';

            const formData = new FormData(bookingForm);
            const data = Object.fromEntries(formData);

            try {
                const res = await fetch('/.netlify/functions/contact-form', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                });

                if (!res.ok) {
                    const err = await res.json();
                    throw new Error(err.error || 'Noe gikk galt');
                }

                // Show success
                bookingForm.style.display = 'none';
                bookingSuccess.style.display = 'block';

                // Reset after 5 seconds
                setTimeout(() => {
                    bookingForm.reset();
                    bookingForm.style.display = '';
                    bookingSuccess.style.display = 'none';
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = `Send Forespørsel <span class="arrow-icon"><svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>`;
                    closeBooking();
                }, 5000);
            } catch (err) {
                alert(err.message || 'En feil oppstod. Prøv igjen senere.');
                submitBtn.disabled = false;
                submitBtn.innerHTML = `Send Forespørsel <span class="arrow-icon"><svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>`;
            }
        });
    </script>
</BaseLayout>
