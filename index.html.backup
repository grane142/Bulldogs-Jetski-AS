    </section>

    <!-- ========== CTA ========== -->
    <section class="cta" id="contact">
        <div class="cta__video-bg">
            <video autoplay muted loop playsinline>
                <source src="https://videos.pexels.com/video-files/5765310/5765310-uhd_2560_1440_30fps.mp4" type="video/mp4">
            </video>
        </div>
        <div class="container">
            <div class="cta__content animate-on-scroll">
                <h2 class="cta__title">Klar for eventyr på vannet?</h2>
                <p class="cta__desc">Book din vannscooter i dag og opplev spenningen med Bulldogg Jetski. Vi sørger for en uforglemmelig opplevelse.</p>
                <a href="mailto:post@bulldoggjetski.no" class="btn-primary">
                    Book Din Tur
                    <span class="arrow-icon">
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                </a>
            </div>
        </div>
    </section>

    <!-- ========== FOOTER ========== -->
    <footer class="footer">
        <div class="container">
            <div class="footer__top">
                <div class="footer__brand">
                    <div class="footer__logo">Bulldogg Jetski</div>
                    <p class="footer__brand-desc">Premium vannscooter utleie med fokus på sikkerhet, kvalitet og uforglemmelige opplevelser på vannet.</p>
                    <div class="footer__social">
                        <a href="#" aria-label="Facebook">
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                        </a>
                        <a href="#" aria-label="Instagram">
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor"/></svg>
                        </a>
                        <a href="#" aria-label="TikTok">
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.11v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.43v-7.1a8.16 8.16 0 005.58 2.19V11.3a4.85 4.85 0 01-3.58-1.59V6.69h3.58z"/></svg>
                        </a>
                    </div>
                </div>

                <div class="footer__col">
                    <h4 class="footer__col-title">Sider</h4>
                    <ul class="footer__col-links">
                        <li><a href="#hero">Hjem</a></li>
                        <li><a href="#about">Om Oss</a></li>
                        <li><a href="#overview">Vannscootere</a></li>
                        <li><a href="#discover">Priser</a></li>
                        <li><a href="#contact">Kontakt</a></li>
                    </ul>
                </div>

                <div class="footer__col">
                    <h4 class="footer__col-title">Tjenester</h4>
                    <ul class="footer__col-links">
                        <li><a href="#overview">Timeleie</a></li>
                        <li><a href="#overview">Dagsleie</a></li>
                        <li><a href="#overview">Helgepakker</a></li>
                        <li><a href="#overview">Gruppearrangementer</a></li>
                        <li><a href="#overview">Bedriftseventer</a></li>
                    </ul>
                </div>

                <div class="footer__newsletter">
                    <h4 class="footer__newsletter-title">Nyhetsbrev</h4>
                    <p class="footer__newsletter-desc">Meld deg på for tilbud, nyheter og sesonginformasjon.</p>
                    <form class="footer__newsletter-form" onsubmit="event.preventDefault(); alert('Takk for påmeldingen!');">
                        <input type="email" class="footer__newsletter-input" placeholder="Din e-postadresse" required>
                        <button type="submit" class="footer__newsletter-btn">Meld På</button>
                    </form>
                </div>
            </div>

            <div class="footer__bottom">
                <p class="footer__copyright">&copy; 2026 Bulldogg Jetski. Alle rettigheter reservert.</p>
                <ul class="footer__bottom-links">
                    <li><a href="#">Personvern</a></li>
                    <li><a href="#">Vilkår</a></li>
                    <li><a href="#">Cookies</a></li>
                </ul>
            </div>
        </div>
    </footer>

    <!-- ========== JAVASCRIPT ========== -->
    <script>
        // ===== Nav scroll effect =====
        const nav = document.getElementById('nav');
        window.addEventListener('scroll', () => {
            nav.classList.toggle('scrolled', window.scrollY > 50);
        });

        // ===== Mobile menu =====
        const mobileToggle = document.getElementById('mobileToggle');
        const mobileMenu = document.getElementById('mobileMenu');
        const mobileClose = document.getElementById('mobileClose');

        mobileToggle.addEventListener('click', () => {
            mobileMenu.classList.add('active');
            document.body.style.overflow = 'hidden';
        });

        mobileClose.addEventListener('click', () => {
            mobileMenu.classList.remove('active');
            document.body.style.overflow = '';
        });

        document.querySelectorAll('.mobile-link').forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.remove('active');
                document.body.style.overflow = '';
            });
        });

        // ===== Smooth scroll =====
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });

        // ===== Scroll animations =====
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, observerOptions);

        document.querySelectorAll('.animate-on-scroll').forEach(el => {
            observer.observe(el);
        });

        // ===== Overview Single-Boat Carousel =====
        const boatData = [
            {
                name: 'Yamaha WaveRunner',
                desc: 'Perfekt for familier og nybegynnere. Stabil, komfortabel vannscooter med plass til 3 passasjerer og enkel håndtering på åpent vann.',
                image: 'https://assets.cdn.filesafe.space/qVvcmGRblTyzZyqPlbTr/media/69c538594880be32be7897a3.webp',
                stat1: '180 HK', stat2: '105 km/t', stat3: 'Opptil 3'
            },
            {
                name: 'Sea-Doo GTX',
                desc: 'Kraftig og stilfull vannscooter med avansert teknologi for en komfortabel og spennende kjøreopplevelse på sjøen.',
                image: 'https://images.pexels.com/photos/1007836/pexels-photo-1007836.jpeg?auto=compress&cs=tinysrgb&w=1600',
                stat1: '230 HK', stat2: '110 km/t', stat3: 'Opptil 3'
            },
            {
                name: 'Kawasaki Ultra 310',
                desc: 'Den ultimate kraftpakken. Uovertruffen ytelse og presisjon for erfarne kjørere som søker ren adrenalin.',
                image: 'https://images.pexels.com/photos/2116475/pexels-photo-2116475.jpeg?auto=compress&cs=tinysrgb&w=1600',
                stat1: '310 HK', stat2: '120 km/t', stat3: 'Opptil 3'
            },
            {
                name: 'Yamaha FX Cruiser',
                desc: 'Luksus på vannet. Premium komfort, stabil kjøring og kraftig motor gjør dette til den perfekte cruiser-opplevelsen.',
                image: 'https://images.pexels.com/photos/1430676/pexels-photo-1430676.jpeg?auto=compress&cs=tinysrgb&w=1600',
                stat1: '250 HK', stat2: '112 km/t', stat3: 'Opptil 3'
            },
            {
                name: 'Sea-Doo RXP-X',
                desc: 'Bygget for fart og konkurranser. Rå kraft og responsiv styring gir den mest intense vannscooteropplevelsen.',
                image: 'https://images.pexels.com/photos/1295036/pexels-photo-1295036.jpeg?auto=compress&cs=tinysrgb&w=1600',
                stat1: '300 HK', stat2: '118 km/t', stat3: 'Opptil 2'
            }
        ];

        const overviewPrev = document.getElementById('overviewPrev');
        const overviewNext = document.getElementById('overviewNext');
        const overviewName = document.getElementById('overviewName');
        const overviewDesc = document.getElementById('overviewDesc');
        const overviewImage = document.getElementById('overviewImage');
        const overviewStat1 = document.getElementById('overviewStat1');
        const overviewStat2 = document.getElementById('overviewStat2');
        const overviewStat3 = document.getElementById('overviewStat3');
        let overviewIndex = 0;
        const overviewTotal = boatData.length;

        function updateOverview() {
            const boat = boatData[overviewIndex];
            overviewName.style.opacity = '0';
            overviewDesc.style.opacity = '0';
            overviewImage.style.opacity = '0';

            setTimeout(() => {
                overviewName.textContent = boat.name;
                overviewDesc.textContent = boat.desc;
                overviewImage.src = boat.image;
                overviewImage.alt = boat.name;
                overviewStat1.textContent = boat.stat1;
                overviewStat2.textContent = boat.stat2;
                overviewStat3.textContent = boat.stat3;

                overviewName.style.opacity = '1';
                overviewDesc.style.opacity = '1';
                overviewImage.style.opacity = '1';
            }, 300);
        }

        overviewNext.addEventListener('click', () => {
            overviewIndex = (overviewIndex + 1) % overviewTotal;
            updateOverview();
        });

        overviewPrev.addEventListener('click', () => {
            overviewIndex = (overviewIndex - 1 + overviewTotal) % overviewTotal;
            updateOverview();
        });

        // ===== Testimonials Carousel =====
        const testimonialsTrack = document.getElementById('testimonialsTrack');
        const testimonialsPrev = document.getElementById('testimonialsPrev');
        const testimonialsNext = document.getElementById('testimonialsNext');
        let testimonialsIndex = 0;
        const testimonialsSlides = testimonialsTrack.querySelectorAll('.testimonials__slide');
        const testimonialsTotal = testimonialsSlides.length;

        function updateTestimonials() {
            testimonialsTrack.style.transform = `translateX(-${testimonialsIndex * 100}%)`;
        }

        testimonialsNext.addEventListener('click', () => {
            testimonialsIndex = (testimonialsIndex + 1) % testimonialsTotal;
            updateTestimonials();
        });

        testimonialsPrev.addEventListener('click', () => {
            testimonialsIndex = (testimonialsIndex - 1 + testimonialsTotal) % testimonialsTotal;
            updateTestimonials();
        });

        // ===== Auto-play carousels =====
        setInterval(() => {
            overviewIndex = (overviewIndex + 1) % overviewTotal;
            updateOverview();
        }, 8000);

        setInterval(() => {
            testimonialsIndex = (testimonialsIndex + 1) % testimonialsTotal;
            updateTestimonials();
        }, 7000);
    </script>
</body>
</html>
