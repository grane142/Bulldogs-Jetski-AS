<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bulldogg Jetski - Premium Vannscooter Utleie</title>
    <meta name="description" content="Opplev spenningen med vannscooter. Bulldogg Jetski tilbyr premium vannscooter utleie med førsteklasses service.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        @font-face {
            font-family: 'Geist';
            src: url('https://framerusercontent.com/assets/FKDA2dJzM5JKsEGMQKYqKkmHaA.woff2') format('woff2');
            font-weight: 100 900;
            font-display: swap;
            font-style: normal;
        }

        /* ========== RESET & BASE ========== */
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --blue: #004b91;
            --dark-blue: #00376b;
            --black: #000000;
            --white: #ffffff;
            --off-white: #f5f5f5;
            --gray-light: #e0e0e0;
            --gray-text: #999999;
            --gray-mid: #666666;
            --border-color: rgba(255,255,255,0.15);
            --border-dark: rgba(0,0,0,0.1);
            --font-geist: 'Geist', sans-serif;
            --font-inter: 'Inter', sans-serif;
        }

        html {
            scroll-behavior: smooth;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        body {
            font-family: var(--font-inter);
            color: var(--black);
            background: var(--white);
            overflow-x: hidden;
            line-height: 1.5;
        }

        a {
            text-decoration: none;
            color: inherit;
            transition: opacity 0.2s;
        }

        a:hover {
            opacity: 0.8;
        }

        img, video {
            display: block;
            max-width: 100%;
        }

        button {
            cursor: pointer;
            border: none;
            background: none;
            font-family: inherit;
        }

        /* ========== UTILITY ========== */
        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px;
            width: 100%;
        }

        .section-label {
            font-family: var(--font-inter);
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--white);
            border: 1px solid var(--border-color);
            border-radius: 100px;
            padding: 10px 20px;
            display: inline-block;
        }

        .section-label--dark {
            color: var(--black);
            border-color: var(--border-dark);
        }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: var(--blue);
            color: var(--white);
            font-family: var(--font-inter);
            font-size: 15px;
            font-weight: 500;
            padding: 14px 28px;
            border-radius: 100px;
            transition: background 0.3s, transform 0.2s;
            white-space: nowrap;
        }

        .btn-primary:hover {
            background: var(--dark-blue);
            opacity: 1;
            transform: translateY(-1px);
        }

        .btn-primary svg {
            width: 16px;
            height: 16px;
            flex-shrink: 0;
        }

        .btn-outline {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: transparent;
            color: var(--white);
            font-family: var(--font-inter);
            font-size: 15px;
            font-weight: 500;
            padding: 14px 28px;
            border-radius: 100px;
            border: 1px solid var(--border-color);
            transition: background 0.3s, transform 0.2s;
            white-space: nowrap;
        }

        .btn-outline:hover {
            background: rgba(255,255,255,0.05);
            opacity: 1;
            transform: translateY(-1px);
        }

        .btn-outline--dark {
            color: var(--black);
            border-color: var(--border-dark);
        }

        .btn-outline--dark:hover {
            background: rgba(0,0,0,0.05);
        }

        .btn-outline svg {
            width: 16px;
            height: 16px;
            flex-shrink: 0;
        }

        /* Arrow icon used in buttons */
        .arrow-icon {
            display: inline-flex;
        }

        /* ========== SCROLL ANIMATIONS ========== */
        .animate-on-scroll {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1), transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
        }

        .animate-on-scroll.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .animate-delay-1 { transition-delay: 0.1s; }
        .animate-delay-2 { transition-delay: 0.2s; }
        .animate-delay-3 { transition-delay: 0.3s; }
        .animate-delay-4 { transition-delay: 0.4s; }

        /* ========== NAVIGATION ========== */
        .nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 16px 0;
            transition: background 0.3s, backdrop-filter 0.3s;
        }

        .nav.scrolled {
            background: rgba(255,255,255,0.9);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
        }

        .nav__inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px;
            border: 1px solid var(--border-color);
            border-radius: 100px;
            height: 60px;
            padding: 0 8px 0 24px;
            transition: border-color 0.3s;
        }

        .nav.scrolled .nav__inner {
            border-color: var(--border-dark);
        }

        .nav.scrolled .nav__logo,
        .nav.scrolled .nav__links a {
            color: var(--black);
        }

        .nav.scrolled .nav__mobile-toggle span {
            background: var(--black);
        }

        .nav__logo {
            font-family: var(--font-geist);
            font-size: 20px;
            font-weight: 600;
            color: var(--white);
            letter-spacing: -0.5px;
            white-space: nowrap;
        }

        .nav__links {
            display: flex;
            align-items: center;
            gap: 32px;
            list-style: none;
        }

        .nav__links a {
            font-family: var(--font-inter);
            font-size: 14px;
            font-weight: 400;
            color: var(--white);
            letter-spacing: 0.5px;
            text-transform: uppercase;
            transition: opacity 0.2s;
        }

        .nav__links a:hover {
            opacity: 0.7;
        }

        .nav__cta .btn-primary {
            padding: 10px 24px;
            font-size: 14px;
        }

        .nav__mobile-toggle {
            display: none;
            flex-direction: column;
            gap: 5px;
            padding: 8px;
            cursor: pointer;
        }

        .nav__mobile-toggle span {
            display: block;
            width: 22px;
            height: 2px;
            background: var(--white);
            transition: transform 0.3s, opacity 0.3s;
        }

        .nav__mobile-menu {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.97);
            z-index: 999;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 32px;
        }

        .nav__mobile-menu.active {
            display: flex;
        }

        .nav__mobile-menu a {
            font-family: var(--font-inter);
            font-size: 24px;
            font-weight: 400;
            color: var(--white);
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .nav__mobile-close {
            position: absolute;
            top: 24px;
            right: 24px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }

        .nav__mobile-close::before,
        .nav__mobile-close::after {
            content: '';
            position: absolute;
            width: 24px;
            height: 2px;
            background: var(--white);
        }

        .nav__mobile-close::before { transform: rotate(45deg); }
        .nav__mobile-close::after { transform: rotate(-45deg); }

        /* ========== HERO ========== */
        .hero {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            overflow: hidden;
        }

        .hero__video-bg {
            position: absolute;
            inset: 0;
            z-index: 0;
        }

        .hero__video-bg video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .hero__video-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.6) 100%);
        }

        .hero__content {
            position: relative;
            z-index: 1;
            max-width: 850px;
            padding: 0 24px;
        }

        .hero__label {
            font-family: var(--font-inter);
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--white);
            margin-bottom: 24px;
            opacity: 0;
            animation: fadeInUp 0.8s 0.3s forwards;
        }

        .hero__title {
            font-family: var(--font-geist);
            font-size: clamp(42px, 7vw, 80px);
            font-weight: 400;
            line-height: 1.05;
            letter-spacing: -2px;
            color: var(--white);
            margin-bottom: 24px;
            opacity: 0;
            animation: fadeInUp 0.8s 0.5s forwards;
        }

        .hero__subtitle {
            font-family: var(--font-inter);
            font-size: 18px;
            font-weight: 300;
            line-height: 1.6;
            color: rgba(255,255,255,0.8);
            max-width: 500px;
            margin: 0 auto 40px;
            opacity: 0;
            animation: fadeInUp 0.8s 0.7s forwards;
        }

        .hero__cta {
            opacity: 0;
            animation: fadeInUp 0.8s 0.9s forwards;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ========== ABOUT SECTION ========== */
        .about {
            padding: 140px 0;
            background: #F8F8F8;
        }

        .about__top {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 60px;
            align-items: start;
            margin-bottom: 60px;
        }

        .about__left {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        .about__label-text {
            font-family: var(--font-inter);
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--black);
            margin-bottom: 24px;
        }

        .about__text {
            font-family: var(--font-geist);
            font-size: clamp(26px, 3.2vw, 38px);
            font-weight: 400;
            line-height: 1.3;
            letter-spacing: -1px;
            color: var(--black);
            max-width: 480px;
            margin-bottom: 32px;
        }

        .about__btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: var(--black);
            color: var(--white);
            font-family: var(--font-inter);
            font-size: 15px;
            font-weight: 500;
            padding: 14px 32px;
            border-radius: 100px;
            transition: background 0.3s, transform 0.2s;
            white-space: nowrap;
        }

        .about__btn:hover {
            background: #222;
            opacity: 1;
            transform: translateY(-1px);
        }

        .about__right-image {
            position: relative;
            border-radius: 16px;
            overflow: hidden;
            width: 100%;
            aspect-ratio: 4/3;
        }

        .about__right-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .about__right-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 32px;
            background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.65) 100%);
            text-align: center;
        }

        .about__right-overlay p {
            font-family: var(--font-inter);
            font-size: 14px;
            font-weight: 300;
            line-height: 1.6;
            color: var(--white);
        }

        .about__bottom-desc {
            font-family: var(--font-inter);
            font-size: 16px;
            font-weight: 300;
            line-height: 1.7;
            color: var(--gray-mid);
            max-width: 550px;
            margin-bottom: 80px;
        }

        .about__stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0;
        }

        .about__stat {
            text-align: center;
            padding: 40px 20px;
            border-left: 1px solid var(--border-dark);
        }

        .about__stat:first-child {
            border-left: none;
        }

        .about__stat-number {
            font-family: var(--font-geist);
            font-size: clamp(36px, 5vw, 56px);
            font-weight: 400;
            letter-spacing: -2px;
            color: var(--black);
            line-height: 1;
            margin-bottom: 12px;
        }

        .about__stat-label {
            font-family: var(--font-inter);
            font-size: 14px;
            font-weight: 400;
            color: var(--gray-text);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* ========== BOATS/JETSKI OVERVIEW ========== */
        .overview {
            padding: 140px 0;
            background: #FFFFFF;
            border-top: 1px solid var(--border-dark);
        }

        .overview__header {
            text-align: center;
            margin-bottom: 40px;
        }

        .overview__label {
            font-family: var(--font-inter);
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--black);
            margin-bottom: 32px;
        }

        .overview__boat-name {
            font-family: var(--font-geist);
            font-size: clamp(36px, 5vw, 56px);
            font-weight: 400;
            line-height: 1.1;
            letter-spacing: -2px;
            color: var(--black);
            margin-bottom: 16px;
            transition: opacity 0.4s;
        }

        .overview__boat-desc {
            font-family: var(--font-inter);
            font-size: 16px;
            font-weight: 300;
            line-height: 1.7;
            color: var(--gray-mid);
            max-width: 500px;
            margin: 0 auto 28px;
            transition: opacity 0.4s;
        }

        .overview__boat-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: var(--black);
            color: var(--white);
            font-family: var(--font-inter);
            font-size: 15px;
            font-weight: 500;
            padding: 14px 32px;
            border-radius: 100px;
            transition: background 0.3s, transform 0.2s;
            white-space: nowrap;
        }

        .overview__boat-btn:hover {
            background: #222;
            opacity: 1;
            transform: translateY(-1px);
        }

        .overview__image-wrapper {
            position: relative;
            margin-top: 60px;
            border-radius: 16px;
            overflow: hidden;
        }

        .overview__image-wrapper img {
            width: 100%;
            aspect-ratio: 16/9;
            object-fit: cover;
            display: block;
            transition: opacity 0.5s;
        }

        .overview__nav {
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            transform: translateY(-50%);
            display: flex;
            justify-content: space-between;
            padding: 0 24px;
            z-index: 2;
            pointer-events: none;
        }

        .overview__nav-btn {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            border: 1px solid rgba(255,255,255,0.4);
            background: rgba(0,0,0,0.3);
            color: var(--white);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.3s, border-color 0.3s;
            cursor: pointer;
            pointer-events: auto;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
        }

        .overview__nav-btn:hover {
            background: rgba(0,0,0,0.5);
            border-color: rgba(255,255,255,0.6);
        }

        .overview__nav-btn svg {
            width: 20px;
            height: 20px;
        }

        .overview__stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0;
            margin-top: 60px;
            border-top: 1px solid var(--border-dark);
        }

        .overview__stat {
            text-align: center;
            padding: 40px 20px;
            border-left: 1px solid var(--border-dark);
        }

        .overview__stat:first-child {
            border-left: none;
        }

        .overview__stat-label {
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--gray-text);
            margin-bottom: 8px;
        }

        .overview__stat-value {
            font-family: var(--font-geist);
            font-size: clamp(24px, 3vw, 32px);
            font-weight: 400;
            letter-spacing: -1px;
            color: var(--black);
        }

        /* ========== DISCOVER SECTION ========== */
        .discover {
            padding: 140px 0;
            background: var(--white);
            border-top: 1px solid var(--border-dark);
        }

        .discover__header {
            text-align: left;
            margin-bottom: 60px;
        }

        .discover__header .section-label {
            margin-bottom: 24px;
        }

        .discover__title {
            font-family: var(--font-geist);
            font-size: clamp(32px, 4vw, 48px);
            font-weight: 400;
            line-height: 1.15;
            letter-spacing: -1.5px;
            color: var(--black);
            max-width: 600px;
        }

        .discover__grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }

        .discover__card {
            border: 1px solid var(--border-dark);
            border-radius: 16px;
            overflow: hidden;
            background: var(--white);
            transition: border-color 0.3s;
        }

        .discover__card:hover {
            border-color: rgba(0,0,0,0.3);
        }

        .discover__card-img {
            width: 100%;
            aspect-ratio: 4/3;
            overflow: hidden;
        }

        .discover__card-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s;
        }

        .discover__card:hover .discover__card-img img {
            transform: scale(1.05);
        }

        .discover__card-body {
            padding: 28px;
        }

        .discover__card-label {
            font-size: 12px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--gray-text);
            margin-bottom: 8px;
        }

        .discover__card-name {
            font-family: var(--font-geist);
            font-size: 24px;
            font-weight: 500;
            color: var(--black);
            margin-bottom: 12px;
            letter-spacing: -0.5px;
        }

        .discover__card-desc {
            font-family: var(--font-inter);
            font-size: 14px;
            font-weight: 300;
            line-height: 1.6;
            color: var(--gray-text);
            margin-bottom: 20px;
        }

        .discover__card-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 24px;
        }

        .discover__card-tag {
            font-family: var(--font-inter);
            font-size: 12px;
            font-weight: 500;
            color: var(--gray-mid);
            border: 1px solid var(--border-dark);
            border-radius: 100px;
            padding: 6px 14px;
            letter-spacing: 0.5px;
        }

        .discover__card-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-family: var(--font-inter);
            font-size: 14px;
            font-weight: 500;
            color: var(--black);
            background: transparent;
            border: 1px solid var(--border-dark);
            border-radius: 100px;
            padding: 12px 24px;
            transition: background 0.3s, border-color 0.3s;
        }

        .discover__card-link:hover {
            background: rgba(0,0,0,0.05);
            border-color: rgba(0,0,0,0.3);
            opacity: 1;
        }

        .discover__card-link svg {
            width: 14px;
            height: 14px;
        }

        .discover__card-price {
            font-family: var(--font-geist);
            font-size: clamp(32px, 4vw, 44px);
            font-weight: 400;
            letter-spacing: -1.5px;
            color: var(--black);
            line-height: 1;
            margin-bottom: 4px;
        }

        .discover__card-price-sub {
            font-family: var(--font-inter);
            font-size: 13px;
            font-weight: 400;
            color: var(--gray-text);
            margin-bottom: 20px;
        }

        .discover__card-features {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 24px;
        }

        .discover__card-feature {
            display: flex;
            align-items: center;
            gap: 10px;
            font-family: var(--font-inter);
            font-size: 14px;
            font-weight: 400;
            color: var(--gray-mid);
        }

        .discover__card-feature svg {
            width: 18px;
            height: 18px;
            color: var(--blue);
            flex-shrink: 0;
        }

        .discover__areas {
            margin-top: 60px;
            text-align: center;
            padding: 40px;
            border: 1px solid var(--border-dark);
            border-radius: 16px;
            background: #F8F8F8;
        }

        .discover__areas-title {
            font-family: var(--font-geist);
            font-size: 20px;
            font-weight: 500;
            color: var(--black);
            margin-bottom: 8px;
            letter-spacing: -0.5px;
        }

        .discover__areas-text {
            font-family: var(--font-inter);
            font-size: 15px;
            font-weight: 300;
            line-height: 1.6;
            color: var(--gray-mid);
        }

        .discover__areas-locations {
            display: flex;
            justify-content: center;
            gap: 24px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        .discover__areas-location {
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: var(--font-inter);
            font-size: 14px;
            font-weight: 500;
            color: var(--black);
        }

        .discover__areas-location svg {
            width: 16px;
            height: 16px;
            color: var(--blue);
        }

        /* ========== INTERIOR/FEATURE SECTION ========== */
        .feature {
            position: relative;
            min-height: 70vh;
            display: flex;
            align-items: center;
            overflow: hidden;
        }

        .feature__bg {
            position: absolute;
            inset: 0;
        }

        .feature__bg img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .feature__bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0) 100%);
        }

        .feature__content {
            position: relative;
            z-index: 1;
            max-width: 520px;
            padding: 100px 0;
        }

        .feature__content .section-label {
            margin-bottom: 24px;
        }

        .feature__title {
            font-family: var(--font-geist);
            font-size: clamp(32px, 4vw, 48px);
            font-weight: 400;
            line-height: 1.15;
            letter-spacing: -1.5px;
            color: var(--white);
            margin-bottom: 20px;
        }

        .feature__desc {
            font-family: var(--font-inter);
            font-size: 16px;
            font-weight: 300;
            line-height: 1.7;
            color: rgba(255,255,255,0.7);
            margin-bottom: 32px;
        }

        /* ========== FOUNDER SECTION ========== */
        .founder {
            padding: 140px 0;
            background: var(--white);
            color: var(--black);
        }

        .founder__inner {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: center;
        }

        .founder__left .section-label--dark {
            margin-bottom: 24px;
        }

        .founder__title {
            font-family: var(--font-geist);
            font-size: clamp(32px, 4vw, 48px);
            font-weight: 400;
            line-height: 1.15;
            letter-spacing: -1.5px;
            color: var(--black);
            margin-bottom: 20px;
        }

        .founder__desc {
            font-family: var(--font-inter);
            font-size: 16px;
            font-weight: 300;
            line-height: 1.7;
            color: var(--gray-mid);
            margin-bottom: 40px;
        }

        .founder__benefits {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .founder__benefit {
            display: flex;
            align-items: flex-start;
            gap: 16px;
        }

        .founder__benefit-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--blue);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .founder__benefit-icon svg {
            width: 18px;
            height: 18px;
            color: var(--white);
        }

        .founder__benefit-text h4 {
            font-family: var(--font-geist);
            font-size: 18px;
            font-weight: 500;
            color: var(--black);
            margin-bottom: 4px;
        }

        .founder__benefit-text p {
            font-family: var(--font-inter);
            font-size: 14px;
            font-weight: 300;
            line-height: 1.6;
            color: var(--gray-mid);
        }

        .founder__right {
            position: relative;
        }

        .founder__image {
            border-radius: 16px;
            overflow: hidden;
            aspect-ratio: 3/4;
        }

        .founder__image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .founder__quote {
            position: absolute;
            bottom: -30px;
            left: -30px;
            background: var(--white);
            border: 1px solid var(--border-dark);
            border-radius: 16px;
            padding: 28px;
            max-width: 320px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
        }

        .founder__quote-text {
            font-family: var(--font-inter);
            font-size: 14px;
            font-weight: 400;
            line-height: 1.6;
            color: var(--black);
            font-style: italic;
            margin-bottom: 16px;
        }

        .founder__quote-author {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .founder__quote-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            overflow: hidden;
            background: var(--gray-light);
        }

        .founder__quote-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .founder__quote-name {
            font-family: var(--font-geist);
            font-size: 14px;
            font-weight: 500;
            color: var(--black);
        }

        .founder__quote-role {
            font-family: var(--font-inter);
            font-size: 12px;
            color: var(--gray-mid);
        }

        /* ========== TESTIMONIALS ========== */
        .testimonials {
            padding: 140px 0;
            background: var(--white);
            border-top: 1px solid var(--border-dark);
        }

        .testimonials__header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 60px;
        }

        .testimonials__header-left {
            max-width: 500px;
        }

        .testimonials__header .section-label {
            margin-bottom: 24px;
        }

        .testimonials__title {
            font-family: var(--font-geist);
            font-size: clamp(32px, 4vw, 48px);
            font-weight: 400;
            line-height: 1.15;
            letter-spacing: -1.5px;
            color: var(--black);
        }

        .testimonials__nav {
            display: flex;
            gap: 12px;
        }

        .testimonials__nav-btn {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            border: 1px solid var(--border-dark);
            background: transparent;
            color: var(--black);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.3s, border-color 0.3s;
            cursor: pointer;
        }

        .testimonials__nav-btn:hover {
            background: rgba(0,0,0,0.05);
            border-color: rgba(0,0,0,0.3);
        }

        .testimonials__nav-btn svg {
            width: 18px;
            height: 18px;
        }

        .testimonials__carousel {
            overflow: hidden;
        }

        .testimonials__track {
            display: flex;
            transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
        }

        .testimonials__slide {
            min-width: 100%;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }

        .testimonial-card {
            border: 1px solid var(--border-dark);
            border-radius: 16px;
            padding: 32px;
            background: var(--white);
        }

        .testimonial-card__stars {
            display: flex;
            gap: 4px;
            margin-bottom: 20px;
        }

        .testimonial-card__stars svg {
            width: 16px;
            height: 16px;
            fill: #f5a623;
            color: #f5a623;
        }

        .testimonial-card__text {
            font-family: var(--font-inter);
            font-size: 15px;
            font-weight: 300;
            line-height: 1.7;
            color: var(--gray-mid);
            margin-bottom: 24px;
        }

        .testimonial-card__author {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .testimonial-card__avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            overflow: hidden;
            background: var(--gray-light);
        }

        .testimonial-card__avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .testimonial-card__name {
            font-family: var(--font-geist);
            font-size: 15px;
            font-weight: 500;
            color: var(--black);
        }

        .testimonial-card__role {
            font-family: var(--font-inter);
            font-size: 13px;
            color: var(--gray-text);
        }

        /* ========== CTA SECTION ========== */
        .cta {
            position: relative;
            padding: 140px 0;
            text-align: center;
            overflow: hidden;
        }

        .cta__video-bg {
            position: absolute;
            inset: 0;
            z-index: 0;
        }

        .cta__video-bg video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .cta__video-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.65);
        }

        .cta__content {
            position: relative;
            z-index: 1;
            max-width: 650px;
            margin: 0 auto;
        }

        .cta__title {
            font-family: var(--font-geist);
            font-size: clamp(36px, 5vw, 56px);
            font-weight: 400;
            line-height: 1.1;
            letter-spacing: -2px;
            color: var(--white);
            margin-bottom: 20px;
        }

        .cta__desc {
            font-family: var(--font-inter);
            font-size: 16px;
            font-weight: 300;
            line-height: 1.7;
            color: rgba(255,255,255,0.7);
            margin-bottom: 40px;
            max-width: 480px;
            margin-left: auto;
            margin-right: auto;
        }

        /* ========== FOOTER ========== */
        .footer {
            padding: 80px 0 40px;
            background: var(--white);
            border-top: 1px solid var(--border-dark);
        }

        .footer__top {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr 1fr;
            gap: 60px;
            margin-bottom: 60px;
        }

        .footer__brand {
            max-width: 300px;
        }

        .footer__logo {
            font-family: var(--font-geist);
            font-size: 22px;
            font-weight: 600;
            color: var(--black);
            margin-bottom: 16px;
            letter-spacing: -0.5px;
        }

        .footer__brand-desc {
            font-family: var(--font-inter);
            font-size: 14px;
            font-weight: 300;
            line-height: 1.7;
            color: var(--gray-text);
            margin-bottom: 24px;
        }

        .footer__social {
            display: flex;
            gap: 12px;
        }

        .footer__social a {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 1px solid var(--border-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.3s, border-color 0.3s;
        }

        .footer__social a:hover {
            background: rgba(0,0,0,0.05);
            border-color: rgba(0,0,0,0.3);
            opacity: 1;
        }

        .footer__social svg {
            width: 16px;
            height: 16px;
            fill: var(--black);
            color: var(--black);
        }

        .footer__col-title {
            font-family: var(--font-geist);
            font-size: 15px;
            font-weight: 500;
            color: var(--black);
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .footer__col-links {
            display: flex;
            flex-direction: column;
            gap: 12px;
            list-style: none;
        }

        .footer__col-links a {
            font-family: var(--font-inter);
            font-size: 14px;
            font-weight: 300;
            color: var(--gray-text);
            transition: color 0.2s;
        }

        .footer__col-links a:hover {
            color: var(--black);
            opacity: 1;
        }

        .footer__newsletter {
            margin-bottom: 0;
        }

        .footer__newsletter-title {
            font-family: var(--font-geist);
            font-size: 15px;
            font-weight: 500;
            color: var(--black);
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .footer__newsletter-desc {
            font-family: var(--font-inter);
            font-size: 14px;
            font-weight: 300;
            line-height: 1.6;
            color: var(--gray-text);
            margin-bottom: 16px;
        }

        .footer__newsletter-form {
            display: flex;
            gap: 8px;
        }

        .footer__newsletter-input {
            flex: 1;
            background: transparent;
            border: 1px solid var(--border-dark);
            border-radius: 100px;
            padding: 12px 20px;
            font-family: var(--font-inter);
            font-size: 14px;
            color: var(--black);
            outline: none;
            transition: border-color 0.3s;
        }

        .footer__newsletter-input::placeholder {
            color: var(--gray-text);
        }

        .footer__newsletter-input:focus {
            border-color: rgba(0,0,0,0.4);
        }

        .footer__newsletter-btn {
            background: var(--blue);
            color: var(--white);
            border: none;
            border-radius: 100px;
            padding: 12px 24px;
            font-family: var(--font-inter);
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: background 0.3s;
            white-space: nowrap;
        }

        .footer__newsletter-btn:hover {
            background: var(--dark-blue);
        }

        .footer__bottom {
            border-top: 1px solid var(--border-dark);
            padding-top: 30px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .footer__copyright {
            font-family: var(--font-inter);
            font-size: 13px;
            color: var(--gray-text);
        }

        .footer__bottom-links {
            display: flex;
            gap: 24px;
            list-style: none;
        }

        .footer__bottom-links a {
            font-family: var(--font-inter);
            font-size: 13px;
            color: var(--gray-text);
        }

        .footer__bottom-links a:hover {
            color: var(--black);
            opacity: 1;
        }

        /* ========== RESPONSIVE - TABLET ========== */
        @media (max-width: 1024px) {
            .nav__links {
                display: none;
            }

            .nav__mobile-toggle {
                display: flex;
            }

            .about__top {
                grid-template-columns: 1fr;
                gap: 40px;
            }

            .about__stats {
                margin-top: 60px;
            }

            .overview__stats {
                grid-template-columns: 1fr;
            }

            .overview__stat {
                border-left: none;
                border-top: 1px solid var(--border-dark);
            }

            .overview__stat:first-child {
                border-top: none;
            }

            .discover__grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .founder__inner {
                grid-template-columns: 1fr;
                gap: 60px;
            }

            .founder__right {
                order: -1;
            }

            .founder__quote {
                position: relative;
                bottom: auto;
                left: auto;
                margin-top: 24px;
                max-width: 100%;
            }

            .testimonials__header {
                flex-direction: column;
                align-items: flex-start;
                gap: 24px;
            }

            .testimonials__slide {
                grid-template-columns: 1fr;
            }

            .footer__top {
                grid-template-columns: 1fr 1fr;
                gap: 40px;
            }

            .footer__bottom {
                flex-direction: column;
                gap: 16px;
                text-align: center;
            }
        }

        /* ========== RESPONSIVE - PHONE ========== */
        @media (max-width: 640px) {
            .nav__inner {
                height: 52px;
                padding: 0 6px 0 18px;
            }

            .nav__logo {
                font-size: 17px;
            }

            .nav__cta .btn-primary {
                padding: 8px 18px;
                font-size: 13px;
            }

            .hero__title {
                letter-spacing: -1px;
            }

            .hero__subtitle {
                font-size: 16px;
            }

            .about {
                padding: 80px 0;
            }

            .about__stats {
                grid-template-columns: 1fr;
                gap: 0;
            }

            .about__stat {
                border-left: none;
                border-top: 1px solid var(--border-dark);
                padding: 28px 20px;
            }

            .about__stat:first-child {
                border-top: none;
            }

            .overview {
                padding: 80px 0;
            }

            .discover {
                padding: 80px 0;
            }

            .feature__content {
                padding: 60px 0;
            }

            .founder {
                padding: 80px 0;
            }

            .testimonials {
                padding: 80px 0;
            }

            .cta {
                padding: 80px 0;
            }

            .footer__top {
                grid-template-columns: 1fr;
                gap: 32px;
            }

            .footer__newsletter-form {
                flex-direction: column;
            }

            .btn-primary, .btn-outline {
                padding: 12px 24px;
                font-size: 14px;
            }
        }
    </style>
</head>
<body>

    <!-- ========== NAVIGATION ========== -->
    <nav class="nav" id="nav">
        <div class="nav__inner">
            <a href="#" class="nav__logo">Bulldogg Jetski</a>
            <ul class="nav__links">
                <li><a href="#about">Om Oss</a></li>
                <li><a href="#overview">Vannscootere</a></li>
                <li><a href="#discover">Priser</a></li>
                <li><a href="#testimonials">Anmeldelser</a></li>
                <li><a href="#contact">Kontakt</a></li>
            </ul>
            <div class="nav__cta">
                <a href="#contact" class="btn-primary">
                    Book Nå
                    <span class="arrow-icon">
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                </a>
            </div>
            <div class="nav__mobile-toggle" id="mobileToggle" aria-label="Open menu">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </nav>

    <!-- Mobile Menu -->
    <div class="nav__mobile-menu" id="mobileMenu">
        <div class="nav__mobile-close" id="mobileClose" aria-label="Close menu"></div>
        <a href="#about" class="mobile-link">Om Oss</a>
        <a href="#overview" class="mobile-link">Vannscootere</a>
        <a href="#discover" class="mobile-link">Priser</a>
        <a href="#testimonials" class="mobile-link">Anmeldelser</a>
        <a href="#contact" class="mobile-link">Kontakt</a>
        <a href="#contact" class="btn-primary" style="margin-top: 20px;">
            Book Nå
            <span class="arrow-icon">
                <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </span>
        </a>
    </div>

    <!-- ========== HERO ========== -->
    <section class="hero" id="hero">
        <div class="hero__video-bg">
            <video autoplay muted loop playsinline>
                <source src="https://assets.cdn.filesafe.space/qVvcmGRblTyzZyqPlbTr/media/69c51a9e7794bf160e36f43e.mp4" type="video/mp4">
            </video>
        </div>
        <div class="hero__content">
            <p class="hero__label">Premium Vannscooter Utleie</p>
            <h1 class="hero__title">Opplev spenningen på vannet.</h1>
            <p class="hero__subtitle">Lei en vannscooter og opplev friheten og adrenalinet på sjøen med Bulldogg Jetski.</p>
            <div class="hero__cta">
                <a href="#overview" class="btn-outline">
                    Utforsk Vannscootere
                    <span class="arrow-icon">
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                </a>
            </div>
        </div>
    </section>

    <!-- ========== ABOUT ========== -->
    <section class="about" id="about">
        <div class="container">
            <div class="about__top">
                <div class="about__left animate-on-scroll">
                    <p class="about__label-text">Uanstrengt &bull; Eventyrlig &bull; Premium</p>
                    <p class="about__text">Vi tilbyr en sømløs vannscooteropplevelse designet for frihet, komfort og oppdagelse.</p>
                    <a href="#overview" class="about__btn">Om Oss</a>
                </div>
                <div class="about__right animate-on-scroll animate-delay-1">
                    <div class="about__right-image">
                        <img src="https://images.pexels.com/photos/1430672/pexels-photo-1430672.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="Vannscooter på sjøen">
                        <div class="about__right-overlay">
                            <p>Vårt lidenskapelige team er dedikert til sikkerhet, komfort og service. Uansett hvor vannet kaller, er Bulldogg Jetski her for å hjelpe.</p>
                        </div>
                    </div>
                </div>
            </div>

            <p class="about__bottom-desc animate-on-scroll animate-delay-2">Bulldogg Jetski er mer enn bare en utleietjeneste — det er din inngangsport til uforglemmelige opplevelser på vannet. Vi startet med en enkel visjon: å gjøre vannscooterkjøring tilgjengelig, stilfullt og stressfritt. I dag hjelper vi eventyrere, familier og utforskere med å skape minner som varer livet ut.</p>

            <div class="about__stats animate-on-scroll animate-delay-3">
                <div class="about__stat">
                    <div class="about__stat-number">15+</div>
                    <div class="about__stat-label">Vannscootere i Flåten</div>
                </div>
                <div class="about__stat">
                    <div class="about__stat-number">2K+</div>
                    <div class="about__stat-label">Fornøyde Kunder</div>
                </div>
                <div class="about__stat">
                    <div class="about__stat-number">8+</div>
                    <div class="about__stat-label">Års Erfaring</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ========== OVERVIEW ========== -->
    <section class="overview" id="overview">
        <div class="container">
            <div class="overview__header animate-on-scroll">
                <p class="overview__label">Vannscooter Oversikt</p>
                <h2 class="overview__boat-name" id="overviewName">Yamaha WaveRunner</h2>
                <p class="overview__boat-desc" id="overviewDesc">Perfekt for familier og nybegynnere. Stabil, komfortabel vannscooter med plass til 3 passasjerer og enkel håndtering på åpent vann.</p>
                <a href="#contact" class="overview__boat-btn">
                    Se Mer
                    <svg viewBox="0 0 16 16" fill="none" width="16" height="16"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
            </div>

            <div class="overview__image-wrapper animate-on-scroll animate-delay-1">
                <div class="overview__nav">
                    <button class="overview__nav-btn" id="overviewPrev" aria-label="Forrige">
                        <svg viewBox="0 0 16 16" fill="none"><path d="M10 4l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                    <button class="overview__nav-btn" id="overviewNext" aria-label="Neste">
                        <svg viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                </div>
                <img id="overviewImage" src="https://assets.cdn.filesafe.space/qVvcmGRblTyzZyqPlbTr/media/69c538594880be32be7897a3.webp" alt="Yamaha WaveRunner">
            </div>

            <div class="overview__stats animate-on-scroll animate-delay-2">
                <div class="overview__stat">
                    <div class="overview__stat-label">Motor</div>
